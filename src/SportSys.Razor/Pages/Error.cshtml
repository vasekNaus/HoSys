@page
@model ErrorModel
@{
    ViewData["Title"] = "Chyba";
}

<p>Při zpracování požadavku došlo k chybě.</p>

@if (Model.ShowRequestId)
{
    <p>
        <strong>ID požadavku:</strong> <code>@Model.RequestId</code>
    </p>
}

<h2>Vývojářský režim</h2>
<p>
    Přepnutím do prostředí <strong>Development</strong> se zobrazí podrobné informace o chybě.
</p>
<p>
    <strong>Vývojářské prostředí by nemělo být povoleno v produkci.</strong>
    Pro lokální ladění nastavte proměnnou prostředí <strong>ASPNETCORE_ENVIRONMENT</strong>
    na hodnotu <strong>Development</strong> a restartujte aplikaci.
</p>
