@using System.Security.Principal

@if (User.Identity?.IsAuthenticated == true)
{
    <span class="text-muted small">
        <i class="fa-solid fa-user fa-fw"></i> @User.Identity?.Name
    </span>
    <a asp-area="MicrosoftIdentity" asp-controller="Account" asp-action="SignOut"
       class="button secondary" style="min-width:auto;padding:.35rem .9rem;">
        <i class="fa-solid fa-right-from-bracket fa-fw"></i> Odhlásit
    </a>
}
else
{
    <a asp-area="MicrosoftIdentity" asp-controller="Account" asp-action="SignIn"
       class="button secondary" style="min-width:auto;padding:.35rem .9rem;">
        <i class="fa-solid fa-right-to-bracket fa-fw"></i> Přihlásit
    </a>
}
